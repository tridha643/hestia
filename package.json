{
  "name": "@tridha643/hestia",
  "version": "1.3.0",
  "description": "Per-worktree isolated development stacks for humans and coding agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/tridha643/hestia"
  },
  "type": "module",
  "workspaces": ["packages/*"],
  "bin": {
    "hestia": "./dist/cli.js"
  },
  "scripts": {
    "hestia": "bun run packages/cli/src/index.ts",
    "test": "bun test",
    "test:tui": "bun test packages/tui/test test/pty",
    "build": "bun run scripts/build-dist.ts",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "19.2.14",
    "portless": "0.15.1",
    "tuistory": "0.0.16",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@opentui/core": "0.4.3",
    "@opentui/react": "0.4.3",
    "react": "19.2.4",
    "yaml": "^2.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "os": ["darwin"],
  "cpu": ["arm64", "x64"],
  "files": [
    "dist",
    "skills/hestia",
    "README.md",
    "NOTICES.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
